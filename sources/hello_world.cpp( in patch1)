#include <iostream>
#include <string>

// Main function: asks user name and prints greeting
int main()
{
    std::string name;                 // variable to store user name
    std::cout << "Enter name: ";      // prompt
    std::cin >> name;                 // read name
    std::cout << "Hello world from @" << name << std::endl; // output
    return 0;
}
